{
	admin off
	persist_config off
	auto_https off
	log {
		format json
	}
	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:3000} {
	log {
		format json
	}

	@health path /health
	respond @health "ok" 200

	root * /app/dist
	encode gzip
	try_files {path} /index.html
	file_server
}
